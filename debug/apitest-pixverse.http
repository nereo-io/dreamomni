###############################################
# PixVerse 特效主流程测试 - 分离的 API
###############################################

### 1. 检查用户积分
GET {{baseUrl}}/api/credits
Content-Type: application/json
Cookie: {{authCookie}}

### 2a. 上传图片 - 通过 URL
POST {{baseUrl}}/api/video-effects/pixverse/upload
Cookie: {{authCookie}}
Content-Type: application/json

{
  "imageUrl": "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=500"
}

### 2b. 生成视频 - 使用上传的图片 ID
# 使用步骤 2a 返回的 imgId
POST {{baseUrl}}/api/video-effects/pixverse/generate
Cookie: {{authCookie}}
Content-Type: application/json

{
  "effectId": "7a6d28d7-09eb-4fd1-b0db-eb877e2f7d8a",
  "imgIds": 756026525,
  "prompt": "a beautiful girl running with 2 cats",
  "duration": 5,
  "quality": "540p",
  "model": "v4.5"
}


### 4. 查看生成历史
GET {{baseUrl}}/api/video-generations/history?page=1&limit=5
Content-Type: application/json
Cookie: {{authCookie}}