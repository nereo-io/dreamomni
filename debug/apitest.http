### ping api (使用Cookie认证)
POST {{baseUrl}}/api/ping
Content-Type: application/json
Cookie: {{authCookie}}

{
  "message": "hello"
}

### get credits
GET {{baseUrl}}/api/credits
Content-Type: application/json
Cookie: {{authCookie}}

### gen image
POST {{baseUrl}}/api/demo/gen-image
Content-Type: application/json
Authorization: Bearer {{apiKey}}

{
  "prompt": "a beautiful girl running with 2 cats",
  "provider": "kling",
  "model": "kling-v1"
}

### gen video
POST {{baseUrl}}/api/demo/gen-video
Content-Type: application/json

{
  "prompt": "a beautiful girl running with 2 cats",
  "provider": "kling",
  "model": "kling-v1-6"
}

### 测试支付创建订单
POST http://localhost:3000/api/checkout
Content-Type: application/json

{
    "priceId": "price_H5ggYwtDq4fbrJ",
    "successUrl": "http://localhost:3000/pay-success",
    "cancelUrl": "http://localhost:3000"
}

### 测试支付回调
POST http://localhost:3000/api/stripe-notify
Content-Type: application/json

{
    "type": "checkout.session.completed",
    "data": {
        "object": {
            "id": "cs_test_xxx",
            "customer": "cus_xxx",
            "subscription": "sub_xxx",
            "payment_status": "paid",
            "amount_total": 1999
        }
    }
}

### 测试检查会员状态
GET http://localhost:3000/api/membership/check
Content-Type: application/json
Cookie: {{authCookie}}

### 测试获取订单列表
GET http://localhost:3000/api/orders
Authorization: Bearer YOUR_ACCESS_TOKEN

### 测试获取单个订单详情
GET http://localhost:3000/api/orders/ORDER_ID
Authorization: Bearer YOUR_ACCESS_TOKEN


### gen text 
POST {{baseUrl}}/api/demo/gen-text
Content-Type: application/json
Authorization: Bearer {{apiKey}}

{
  "prompt": "9.11 vs 9.8, which one is greater?",
  "provider": "openrouter",
  "model": "deepseek/deepseek-r1"
}


### update-invite
POST {{baseUrl}}/api/update-invite
Content-Type: application/json
Cookie: {{authCookie}}

{
  "invite_code": "index",
  "user_uuid": "f6918568-fd27-4fb8-9273-3ba4d9ac4bd3"
}

### update-invite-code
POST {{baseUrl}}/api/update-invite-code
Content-Type: application/json
Cookie: {{authCookie}}

{
  "invite_code": "index"
}

### get-user-info
POST {{baseUrl}}/api/get-user-info
Content-Type: application/json
Cookie: {{authCookie}}
