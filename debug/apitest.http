### 异步提交视频生成任务 - Kling 1.6
POST {{baseUrl}}/api/video-generation/submit
Content-Type: application/json

{
  "model": "kling-1-6",
  "prompt": "A stylish woman walks down a Tokyo street filled with warm glowing neon and animated city signage. She moves gracefully through the bustling crowd, her dress flowing in the breeze.",
  "image_url": "https://storage.googleapis.com/falserverless/kling/kling_input.jpeg",
  "duration": "10",
  "aspect_ratio": "16:9",
  "negative_prompt": "static pose, frozen movement, low quality",
  "cfg_scale": 0.5,
  "webhook_url": "https://your-domain.com/webhook/video-complete"
}

### 异步提交视频生成任务 - Kling 2.0 Master
POST {{baseUrl}}/api/video-generation/submit
Content-Type: application/json

{
  "model": "kling-2-0-master",
  "prompt": "A cinematic sequence of a lone warrior standing on a cliff overlooking a vast battlefield at sunset, with epic camera movements and dramatic lighting",
  "image_url": "https://v3.fal.media/files/elephant/rkH-9qoXtXu3rAYTsx9V5_image.webp",
  "duration": "10",
  "aspect_ratio": "16:9",
  "negative_prompt": "poor cinematography, amateur lighting, low resolution",
  "cfg_scale": 0.7,
  "webhook_url": "https://your-domain.com/webhook/video-complete"
}

