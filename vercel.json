{
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/distribute-credits",
      "schedule": "*/30 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/get_details",
      "destination": "https://t.firstpromoter.com/get_details"
    },
    {
      "source": "/tr",
      "destination": "https://t.firstpromoter.com/tr"
    }
  ]
}
