### 获取客户信息列表 - 未授权测试
GET {{baseUrl}}/customer-info/list

### 获取客户信息列表 - 使用 Session Token
GET {{baseUrl}}/customer-info/list
Cookie: {{authToken}}

### 测试创建聊天会话
POST {{baseUrl}}/chat-session
Content-Type: application/json
Cookie: {{authToken}}

{
  "uuid": "{{chatId}}",
  "user_uuid": "785a4c2e-5ccc-4c50-9160-7bfc4e98bbfc",
  "title": "测试聊天会话",
  "status": "new",
  "created_at": "2024-01-01",
  "updated_at": "2024-01-01",
  "customer_info_id": "57b2695b-b1e3-4c81-adc8-f9d35a24b96f"
}

### 测试get聊天会话
GET {{baseUrl}}/chat-session/{{chatId}}
Cookie: {{authToken}}

### 更新聊天会话状态
PUT {{baseUrl}}/chat-session/{{chatId}}
Content-Type: application/json
Cookie: {{authToken}}

{
  "status": "created"
}

### 获取聊天消息列表
GET {{baseUrl}}/chat-session/{{chatId}}/messages
Cookie: {{authToken}}

### 发送新消息
POST {{baseUrl}}/chat-session/{{chatId}}/messages
Content-Type: application/json
Cookie: {{authToken}}

{
  "role": "user",
  "content": "这是一条测试消息",
  "reasoning_content": "这是一条测试推理消息"
}

### 未授权测试 - 创建会话
POST {{baseUrl}}/chat-session
Content-Type: application/json

{
  "title": "未授权测试"
}

### 未授权测试 - 获取会话
GET {{baseUrl}}/chat-session/{{chatId}}

### 获取会话
GET {{baseUrl}}/chat-session/{{chatId}}
Cookie: {{authToken}}
