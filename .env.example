# -----------------------------------------------------------------------------
# Web Information
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WEB_URL = "https://dreamomni.ai"
NEXT_PUBLIC_PROJECT_NAME = "DreamOmni"

# -----------------------------------------------------------------------------
# Database with Supabase
# -----------------------------------------------------------------------------
# https://supabase.com/docs/guides/getting-started/quickstarts/nextjs
# Set your Supabase URL and service role key for server-side access
SUPABASE_URL = ""
SUPABASE_SERVICE_ROLE_KEY = ""

# -----------------------------------------------------------------------------
# Auth with next-auth
# https://authjs.dev/getting-started/installation?framework=Next.js
# Set your Auth URL and Secret
# Secret can be generated with `openssl rand -base64 32`
# -----------------------------------------------------------------------------
AUTH_SECRET = ""
NEXTAUTH_URL = "https://dreamomni.ai"

# Google Auth
# https://authjs.dev/getting-started/providers/google
AUTH_GOOGLE_ID = ""
AUTH_GOOGLE_SECRET = ""
NEXT_PUBLIC_AUTH_GOOGLE_ID = ""
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED = "false"
NEXT_PUBLIC_AUTH_GOOGLE_ONE_TAP_ENABLED = "false"

# Github Auth
# https://authjs.dev/getting-started/providers/github
AUTH_GITHUB_ID = ""
AUTH_GITHUB_SECRET = ""
NEXT_PUBLIC_AUTH_GITHUB_ENABLED = "false"

# Apple Auth
# https://authjs.dev/getting-started/providers/apple
AUTH_APPLE_ID = ""
AUTH_APPLE_SECRET = ""
NEXT_PUBLIC_AUTH_APPLE_ENABLED = "false"

# VK Auth
# https://authjs.dev/getting-started/providers/vk
AUTH_VK_ID = ""
AUTH_VK_SECRET = ""
NEXT_PUBLIC_AUTH_VK_ENABLED = "false"

# Email Auth
NEXT_PUBLIC_AUTH_EMAIL_ENABLED = "true"

# -----------------------------------------------------------------------------
# CAPTCHA with Cloudflare Turnstile
# https://developers.cloudflare.com/turnstile/
# -----------------------------------------------------------------------------
# Get your keys from Cloudflare Dashboard > Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY = ""
TURNSTILE_SECRET_KEY = ""

# -----------------------------------------------------------------------------
# Analytics with Google Analytics
# https://analytics.google.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID = ""
NEXT_PUBLIC_GOOGLE_ADS_ID = ""

# -----------------------------------------------------------------------------
# Analytics with OpenPanel
# https://openpanel.dev
# -----------------------------------------------------------------------------
NEXT_PUBLIC_OPENPANEL_CLIENT_ID = ""

# -----------------------------------------------------------------------------
# Yandex Metrica
# https://metrica.yandex.com/
# -----------------------------------------------------------------------------
NEXT_PUBLIC_YANDEX_METRICA_ID = ""
YANDEX_METRICA_OAUTH_TOKEN = ""
# Legacy alias (kept for backward compatibility)
YANDEX_OFFLINE_CONVERSION_TOKEN = ""
# Goal name or numeric target configured in Metrica
YANDEX_METRICA_PAYMENT_GOAL_TARGET = "PAYMENT_SUCCESS"
# Optional numeric Metrica goal id for payment conversions (preferred over GOAL_TARGET when set)
YANDEX_METRICA_PAYMENT_GOAL_ID = ""

# -----------------------------------------------------------------------------
# Microsoft Advertising UET (Bing Ads)
# https://help.ads.microsoft.com/apex/index/3/en/56682
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BING_UET_ID = ""

# -----------------------------------------------------------------------------
# FirstPromoter Affiliate Tracking
# https://docs.firstpromoter.com/guides/tracking-with-fprjs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIRST_PROMOTER_ACCOUNT_ID = ""
FIRST_PROMOTER_API_KEY = ""

# -----------------------------------------------------------------------------
# Payment with Stripe
# https://docs.stripe.com/keys
# -----------------------------------------------------------------------------
STRIPE_PUBLIC_KEY = ""
STRIPE_PRIVATE_KEY = ""
STRIPE_WEBHOOK_SECRET = ""

# Optional Stripe Dashboard Price IDs (override).
# By default checkout creates inline price_data from config/products.ts amounts.
# To instead charge a pre-created Stripe price, set STRIPE_PRICE_<PRODUCT_ID>
# (e.g. STRIPE_PRICE_MINI_MONTHLY, STRIPE_PRICE_BUNDLE_20). Leave unset to use amounts.

# -----------------------------------------------------------------------------
# Payment with Creem (primary for non-Russia regions)
# https://creem.io
# -----------------------------------------------------------------------------
CREEM_API_KEY = ""
CREEM_API_SECRET = ""
CREEM_WEBHOOK_SECRET = ""
# Optional base URL override (test vs live)
CREEM_BASE_URL = ""

# -----------------------------------------------------------------------------
# Payment with Payssion V2 (Russia regions)
# https://payssion.com
# -----------------------------------------------------------------------------
PAYSSION_V2_API_KEY = ""
PAYSSION_V2_SECRET_KEY = ""
PAYSSION_V2_BASE_URL = ""

NEXT_PUBLIC_PAY_SUCCESS_URL = "https://dreamomni.ai/my-orders"
NEXT_PUBLIC_PAY_FAIL_URL = "https://dreamomni.ai/#pricing"
NEXT_PUBLIC_PAY_CANCEL_URL = "https://dreamomni.ai/#pricing"

NEXT_PUBLIC_LOCALE_DETECTION = "false"

ADMIN_EMAILS = ""

NEXT_PUBLIC_DEFAULT_THEME = "light"
NEXT_PUBLIC_AGENT_INTERNALS = "false"

# -----------------------------------------------------------------------------
# Cron Jobs
# -----------------------------------------------------------------------------
# Secret for authenticating cron job requests
# Generate with: openssl rand -base64 32
CRON_SECRET = ""

# Secret for authenticating internal API requests
# Generate with: openssl rand -base64 32
INTERNAL_API_KEY = ""

# -----------------------------------------------------------------------------
# Storage with aws s3 sdk
# https://docs.aws.amazon.com/s3/index.html
# -----------------------------------------------------------------------------
STORAGE_ENDPOINT = ""
STORAGE_REGION = ""
STORAGE_ACCESS_KEY = ""
STORAGE_SECRET_KEY = ""
STORAGE_BUCKET = ""
STORAGE_DOMAIN = ""

# -----------------------------------------------------------------------------
# AI Image Generation Providers
# -----------------------------------------------------------------------------
# Kie.ai (shared by Nano Banana and GPT Image 2 image providers)
# https://kie.ai
KIE_AI_API_KEY = ""
# Optional override; defaults to https://api.kie.ai
KIE_AI_BASE_URL = ""

# fal.ai (used by FalImageProvider and as Nano Banana fallback)
FAL_KEY = ""
# Toggle image-generation fal.ai fallback (true/false)
FALLBACK_TO_FAL_ENABLED = "false"

# -----------------------------------------------------------------------------
# AI Video Generation Providers
# (read by services/providers/* through ProviderFactory)
# -----------------------------------------------------------------------------
# Volcano Engine / ByteDance — Doubao-Seedance
ARK_API_KEY = ""
# Optional outbound proxy for Volcano requests (both must be set to enable)
PROXY_URL = ""
PROXY_SECRET = ""
# Toggle Volcano/Seedance fallback path (true/false)
ENABLE_VOLCANO_FALLBACK = "false"

# BytePlus — Seedance (Southeast Asia)
BYTEPLUS_API_KEY = ""

# APICore — Veo3
APICORE_API_KEY = ""

# Ali Cloud (Bailian) — domestic + international keys
ALI_API_KEY = ""
ALI_API_KEY_INTL = ""

# Evolink
EVOLINK_API_KEY = ""
EVOLINK_BASE_URL = ""

# MaxAPI — Seedance 2.0
MAXAPI_API_KEY = ""
MAXAPI_BASE_URL = ""

# PixVerse — video / image effects
PIXVERSE_API_KEY = ""

# Kie.ai Gemini Omni: pre-upload reference inputs before submit (true/false)
KIE_GEMINI_OMNI_PREUPLOAD_INPUTS = "false"

# -----------------------------------------------------------------------------
# Internal / Integrations
# -----------------------------------------------------------------------------
# Auth token required by internal-only API routes (/api/internal/*)
INTERNAL_API_KEY = ""
# Python agent service base URL (defaults to http://localhost:8000)
PYTHON_AGENT_URL = ""
# Outrank content webhook auth token (/api/outrank/webhook)
OUTRANK_WEBHOOK_SECRET = ""

# -----------------------------------------------------------------------------
# Video callback signature
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
VIDEO_CALLBACK_SIGNING_SECRET = ""
# Callback URL signature validity window in minutes (default 1440)
VIDEO_CALLBACK_TTL_MINUTES = "1440"
